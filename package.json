{
  "name": "redalia-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "audit:feed-socios": "node scripts/audit-feed-socios.mjs",
    "audit:kiteprop-network": "node scripts/kiteprop-network-audit.mjs",
    "verify:deploy": "node scripts/deploy-readiness.mjs",
    "repo:apply-branch-protection": "node scripts/apply-branch-protection.mjs",
    "verify:network-ingest": "node scripts/network-ingest-verify.mjs",
    "catalog:sources-probe": "node scripts/catalog-sources-probe.mjs",
    "env:pull:vercel": "npx --yes vercel@latest env pull .env.local",
    "repo:branch-alignment": "node scripts/repo-branch-alignment.mjs",
    "sync:pull": "git fetch origin --prune && git pull --rebase origin main",
    "sync": "npm run sync:pull && git push origin main",
    "sync:auto": "git stash push -u -m sync-auto >/dev/null 2>&1 || true; git fetch origin --prune && git pull --rebase origin main && git push origin main; status=$?; git stash pop >/dev/null 2>&1 || true; exit $status"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
