# --- Producción recomendada (fuente de verdad fijada; ver docs/redalia-hybrid-catalog-architecture.md) ---
# Propiedades + fotos: JSON de difusión (no usar `network` como motor del listing salvo excepción explícita).
KITEPROP_PROPERTIES_SOURCE=json
# URL real del JSON (obligatoria en Vercel si el default del repo no es el feed de tu sitio).
KITEPROP_PROPERTIES_URL=
# Directorio /socios: API de red (anunciante canónico; organización en extras y contexto).
REDALIA_PARTNER_DIRECTORY_SOURCE=network
# Origen absoluto de logos relativos del API (logos de socios / media KiteProp).
# KITEPROP_PUBLIC_ORIGIN=https://www.kiteprop.com
# Con `KITEPROP_PROPERTIES_SOURCE=json`, por defecto se llama a organizaciones de red (`kpnet:org:*`).
# Desactivar: KITEPROP_MERGE_NETWORK_ORGANIZATIONS=0
# KITEPROP_MERGE_NETWORK_ORGANIZATIONS=

# Solo "1" para NO rellenar con muestra si tu feed remoto devuelve 0 ítems (útil para QA de feed vacío).
# KITEPROP_PROPERTIES_STRICT_EMPTY=
# Sin URL de feed: en desarrollo (`NODE_ENV` ≠ production) se puede usar muestra local; `0` la desactiva. Producción con URL ignora muestra.
# KITEPROP_PROPERTIES_ALLOW_SAMPLE=

# Origen del catálogo (alternativas; **no** recomendado como default de producto):
# `network` / `aina` = solo API de red para propiedades (sin fallback al feed JSON).
# `network_fallback_json` = red primero; si falla o 0 propiedades, entonces feed JSON.
# Ver docs/catalog-operaciones.md

# Ingest catálogo (server) + cron Vercel — ver docs/ingestion-feed-plan.md
# TTL segundos para caché de `getProperties` (default 7200; min 60, max 86400).
# CATALOG_INGEST_REVALIDATE_SECONDS=7200
# Solo "1" en local: omitir caché Next del catálogo.
# CATALOG_INGEST_DISABLE_CACHE=
# Secreto para GET /api/cron/catalog (Authorization: Bearer …). Vercel Cron lo envía si está en el proyecto.
# CRON_SECRET=
# Solo "1": una línea JSON por corrida de ingest en logs server (sin secretos). Ver docs/ingestion-feed-plan.md §8.
# CATALOG_INGEST_LOG=

# No recomendado exponer URL de feed grande al cliente
NEXT_PUBLIC_KITEPROP_PROPERTIES_URL=

# URL canónica (Open Graph / metadata)
NEXT_PUBLIC_SITE_URL=https://redalia.vercel.app

# WhatsApp público (opcional). Por defecto el sitio usa el número institucional en lib/site-config.ts
# (+56 9 8455 3691). Podés forzar otro valor con estas variables:
# Opción A — número Chile, solo dígitos:
# NEXT_PUBLIC_WHATSAPP_NUMBER=56984553691
# Opción B — enlace completo:
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/56984553691
# Etiqueta opcional para mostrar en la UI:
# NEXT_PUBLIC_WHATSAPP_LABEL=+56 9 8455 3691

# LinkedIn u otra red (opcional). No uses "#" en producción.
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/...

# URL del portal de acceso para socios (opcional). Por defecto: login KiteProp.
# NEXT_PUBLIC_MEMBERS_PORTAL_URL=https://...

# --- Formularios Contacto / Únete ---
LEADS_WEBHOOK_URL=

# --- API REST KiteProp (server-only) ---
# Una sola secret (recomendado): mismo kp_… que en MCP (~/.cursor/mcp.json → KITEPROP_API_TOKEN del paquete crm-mcp).
# KITEPROP_API_SECRET=
# Si preferís nombres por cabecera, podés omitir API_SECRET y usar solo estas (mismo valor repetido si aplica):
# KITEPROP_API_KEY=              # X-API-Key → GET /profile
# KITEPROP_ACCESS_TOKEN=         # Bearer → GET /properties, /users, …
# KITEPROP_API_TOKEN=            # Bearer → POST leads (con KITEPROP_LEAD_POST_URL)
# Detalle: docs/kiteprop-credentials.md
# Opcional; por defecto https://www.kiteprop.com/api/v1
# KITEPROP_API_BASE_URL=https://www.kiteprop.com/api/v1
# Solo "1" habilita GET /api/test-kiteprop y GET /api/test-kiteprop-properties (resto del tiempo: 404). Ver docs/kiteprop-api-1.md y docs/kiteprop-api-properties-investigation.md
# KITEPROP_ENABLE_API_TEST=

# GET /properties y GET /users: si es "1", envían Authorization Bearer + X-API-Key (user+pass para JWT si no hay ACCESS_TOKEN/SECRET).
# KITEPROP_REST_BEARER_WITH_API_KEY=

# KITEPROP_LEAD_POST_URL=https://www.kiteprop.com/api/v1/...
# Bearer para POST leads: KITEPROP_API_TOKEN o fallback KITEPROP_API_SECRET
# KITEPROP_API_TOKEN=
# Endpoint legacy opcional para /api/consultas; si está definido, reemplaza el envío directo a KiteProp.
# KITEPROP_API_CONSULTA_URL=

# --- Señales MCP → Home (opcional; snapshot agregado, sin PII). Ver docs/kiteprop-mcp-redalia-mvp.md ---
# URL HTTPS a JSON v1 (revalidación ~1 h en servidor)
# KITEPROP_MCP_PUBLIC_SNAPSHOT_URL=
# Archivo bajo data/ (default: kiteprop-mcp-public-snapshot.json; ver .gitignore)
# KITEPROP_MCP_PUBLIC_SNAPSHOT_FILE=

# --- Red AINA / KiteProp (misma fuente que el producto en producción; server-only) ---
# Ver docs/kiteprop-network-aina.md. Defaults = mismas URLs que AINA (token en path + JWT login).
# Base REST (este nombre es el que lee el código; no usar KITEPROP_API_BASE suelto).
# KITEPROP_API_BASE_URL=https://www.kiteprop.com/api/v1
# KITEPROP_API_USER=
# KITEPROP_API_PASSWORD=
# KITEPROP_NETWORK_ID=
# KITEPROP_NETWORK_TOKEN=
# Origen web para resolver logos relativos del API (`/storage/...`). Default: https://www.kiteprop.com
# KITEPROP_PUBLIC_ORIGIN=
# Recomendado en Vercel: NO definir las dos siguientes; el servidor arma paths con id+token.
# Si las definís, SOLO placeholders literales {networkId} y {networkToken} (no {19}, no token pegado a mano):
#   /networks/{networkId}/{networkToken}/organizations
#   /properties/network/{networkId}/{networkToken}
# Mal: /networks/19/organizations (falta el token en el path; AINA siempre lo incluye).
# KITEPROP_NETWORK_ORGANIZATIONS_PATH=
# KITEPROP_NETWORK_PROPERTIES_PATH=
# KITEPROP_AUTH_LOGIN_PATH=auth/login
# KITEPROP_AUTH_LOGIN_USER_FIELD=email
# KITEPROP_AUTH_LOGIN_PASSWORD_FIELD=password
# KITEPROP_NETWORK_ID_HEADER=X-Network-Id
# KITEPROP_NETWORK_TOKEN_HEADER=X-Network-Token
# Solo "1" si el Bearer de las GET de red debe ser KITEPROP_NETWORK_TOKEN (caso raro; AINA suele usar JWT + cabecera)
# KITEPROP_NETWORK_TOKEN_AS_BEARER=
# Origen del directorio público /socios: `network` (default en código si la env está vacía) | merge | feed
# REDALIA_PARTNER_DIRECTORY_SOURCE=network
# Paginación API red (propiedades): default 150 páginas × limit 50 = 7500; techo 1000 páginas vía MAX_PAGES
# KITEPROP_NETWORK_PROPERTIES_PAGED_FETCH=1
# Filtro opcional de estado para red (vacío = sin filtro, `active` = solo activas)
# KITEPROP_NETWORK_PROPERTIES_STATUS=active
# KITEPROP_NETWORK_PROPERTIES_PAGE_LIMIT=50
# KITEPROP_NETWORK_PROPERTIES_MAX_PAGES=150
# Pacing y reintentos contra 429/5xx de la red API
# KITEPROP_NETWORK_REQUEST_DELAY_MS=140
# KITEPROP_NETWORK_REQUEST_RETRY_ATTEMPTS=4
# Solo "1" habilita GET /api/test-kiteprop-network-audit (resto: 404)
# KITEPROP_NETWORK_AUDIT_ENABLED=
