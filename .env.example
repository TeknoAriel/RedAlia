# Feed de propiedades (JSON de difusión KiteProp: catálogo + datos para inmobiliarias/socios en el sitio).
# Si está vacío, se usa data/kiteprop-sample.json.
# Opcional: otra URL de difusión. Si se omite, `lib/config.ts` usa el feed externalsite por defecto.
# KITEPROP_PROPERTIES_URL=https://static.kiteprop.com/kp/difusions/4b3c894a10d905c82e85b35c410d7d4099551504/externalsite-274-824a1c8e7d598497d49e0ad573e2a8dc63d82c63.json
KITEPROP_PROPERTIES_URL=

# Origen del catálogo: omitir o `json` = solo este feed arriba (recomendado para propiedades + inmobiliarias desde JSON).
# `network` / `aina` = API de red (credenciales aparte). `network_fallback_json` = intenta red y si falla usa el feed.
# KITEPROP_PROPERTIES_SOURCE=

# No recomendado exponer URL de feed grande al cliente
NEXT_PUBLIC_KITEPROP_PROPERTIES_URL=

# URL canónica (Open Graph / metadata)
NEXT_PUBLIC_SITE_URL=https://redalia.vercel.app

# WhatsApp público (opcional). Por defecto el sitio usa el número institucional en lib/site-config.ts
# (+56 9 8455 3691). Podés forzar otro valor con estas variables:
# Opción A — número Chile, solo dígitos:
# NEXT_PUBLIC_WHATSAPP_NUMBER=56984553691
# Opción B — enlace completo:
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/56984553691
# Etiqueta opcional para mostrar en la UI:
# NEXT_PUBLIC_WHATSAPP_LABEL=+56 9 8455 3691

# LinkedIn u otra red (opcional). No uses "#" en producción.
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/...

# URL del portal de acceso para socios (opcional). Por defecto: login KiteProp.
# NEXT_PUBLIC_MEMBERS_PORTAL_URL=https://...

# --- Formularios Contacto / Únete ---
LEADS_WEBHOOK_URL=

# --- API REST KiteProp (server-only) ---
# Una sola secret (recomendado): mismo kp_… que en MCP (~/.cursor/mcp.json → KITEPROP_API_TOKEN del paquete crm-mcp).
# KITEPROP_API_SECRET=
# Si preferís nombres por cabecera, podés omitir API_SECRET y usar solo estas (mismo valor repetido si aplica):
# KITEPROP_API_KEY=              # X-API-Key → GET /profile
# KITEPROP_ACCESS_TOKEN=         # Bearer → GET /properties, /users, …
# KITEPROP_API_TOKEN=            # Bearer → POST leads (con KITEPROP_LEAD_POST_URL)
# Detalle: docs/kiteprop-credentials.md
# Opcional; por defecto https://www.kiteprop.com/api/v1
# KITEPROP_API_BASE_URL=https://www.kiteprop.com/api/v1
# Solo "1" habilita GET /api/test-kiteprop y GET /api/test-kiteprop-properties (resto del tiempo: 404). Ver docs/kiteprop-api-1.md y docs/kiteprop-api-properties-investigation.md
# KITEPROP_ENABLE_API_TEST=

# GET /properties y GET /users: si es "1", envían Authorization Bearer + X-API-Key (user+pass para JWT si no hay ACCESS_TOKEN/SECRET).
# KITEPROP_REST_BEARER_WITH_API_KEY=

# KITEPROP_LEAD_POST_URL=https://www.kiteprop.com/api/v1/...
# Bearer para POST leads: KITEPROP_API_TOKEN o fallback KITEPROP_API_SECRET
# KITEPROP_API_TOKEN=

# --- Señales MCP → Home (opcional; snapshot agregado, sin PII). Ver docs/kiteprop-mcp-redalia-mvp.md ---
# URL HTTPS a JSON v1 (revalidación ~1 h en servidor)
# KITEPROP_MCP_PUBLIC_SNAPSHOT_URL=
# Archivo bajo data/ (default: kiteprop-mcp-public-snapshot.json; ver .gitignore)
# KITEPROP_MCP_PUBLIC_SNAPSHOT_FILE=

# --- Red AINA / KiteProp (misma fuente que el producto en producción; server-only) ---
# Ver docs/kiteprop-network-aina.md. Defaults = mismas URLs que AINA (token en path + JWT login).
# KITEPROP_API_USER=
# KITEPROP_API_PASSWORD=
# KITEPROP_NETWORK_ID=
# KITEPROP_NETWORK_TOKEN=
# Opcional: plantillas con {networkId} y {networkToken}; si faltan, defaults AINA:
#   GET …/networks/{id}/{token}/organizations
#   GET …/properties/network/{id}/{token}?status=active
# KITEPROP_NETWORK_ORGANIZATIONS_PATH=
# KITEPROP_NETWORK_PROPERTIES_PATH=
# KITEPROP_AUTH_LOGIN_PATH=auth/login
# KITEPROP_AUTH_LOGIN_USER_FIELD=email
# KITEPROP_AUTH_LOGIN_PASSWORD_FIELD=password
# KITEPROP_NETWORK_ID_HEADER=X-Network-Id
# KITEPROP_NETWORK_TOKEN_HEADER=X-Network-Token
# Solo "1" si el Bearer de las GET de red debe ser KITEPROP_NETWORK_TOKEN (caso raro; AINA suele usar JWT + cabecera)
# KITEPROP_NETWORK_TOKEN_AS_BEARER=
# Solo "1" habilita GET /api/test-kiteprop-network-audit (resto: 404)
# KITEPROP_NETWORK_AUDIT_ENABLED=
