# Feed JSON de KiteProp (opcional). Si está vacío, el sitio usa data/kiteprop-sample.json
# Ejemplo real (pesado; solo en servidor / Vercel):
# KITEPROP_PROPERTIES_URL=https://static.kiteprop.com/kp/difusions/.../....json
KITEPROP_PROPERTIES_URL=

# Opcional: misma URL si necesitás exponerla al cliente (no recomendado para feeds grandes)
NEXT_PUBLIC_KITEPROP_PROPERTIES_URL=

# URL canónica (Open Graph / metadata). Producción: proyecto Vercel "redalia"
NEXT_PUBLIC_SITE_URL=https://redalia.vercel.app

# --- Leads (formularios Contacto / Únete) ---
LEADS_WEBHOOK_URL=

# KITEPROP_LEAD_POST_URL=https://www.kiteprop.com/api/v1/...
# KITEPROP_API_TOKEN=
