{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "ignoreCommand": "bash scripts/vercel-ignore-non-main.sh",
  "crons": [
    {
      "path": "/api/cron/catalog",
      "schedule": "0 6 * * *"
    }
  ]
}
